#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
ENV_FILE="${SCRIPT_DIR}/../.env"

if ! command -v opencode >/dev/null 2>&1; then
  echo "[opencode-lf] opencode not found in PATH" >&2
  exit 1
fi

if [[ ! -f "$ENV_FILE" ]]; then
  echo "[opencode-lf] .env not found: $ENV_FILE" >&2
  exit 1
fi

# Read only required Langfuse vars without leaking secrets to logs.
# Supports both `KEY=value` and `export KEY=value`, including quoted values.
read_from_env_file() {
  local key="$1"
  python3 - "$ENV_FILE" "$key" <<'PY'
import re
import sys
from pathlib import Path

env_file = Path(sys.argv[1])
target = sys.argv[2]
pattern = re.compile(r"^(?:export\s+)?([A-Za-z_][A-Za-z0-9_]*)\s*=\s*(.*)$")


def parse_value(raw: str) -> str:
    value = raw.strip()
    if not value:
        return ""

    if value[0] == "'":
        out = []
        i = 1
        while i < len(value):
            c = value[i]
            if c == "'":
                return "".join(out)
            out.append(c)
            i += 1
        raise ValueError("unclosed single quote")

    if value[0] == '"':
        out = []
        i = 1
        while i < len(value):
            c = value[i]
            if c == '"':
                return "".join(out)
            if c == "\\" and i + 1 < len(value):
                nxt = value[i + 1]
                escapes = {"n": "\n", "r": "\r", "t": "\t", '"': '"', "\\": "\\"}
                out.append(escapes.get(nxt, nxt))
                i += 2
                continue
            out.append(c)
            i += 1
        raise ValueError("unclosed double quote")

    return value


result = ""
for raw_line in env_file.open("r", encoding="utf-8", errors="replace"):
    line = raw_line.strip()
    if not line or line.startswith("#"):
        continue
    match = pattern.match(line)
    if not match:
        continue
    key, raw_value = match.group(1), match.group(2)
    if key != target:
        continue
    try:
        result = parse_value(raw_value)
    except ValueError as exc:
        print(f"invalid value for {target}: {exc}", file=sys.stderr)
        sys.exit(2)

print(result, end="")
PY
}

LANGFUSE_BASE_URL_RAW="$(read_from_env_file LANGFUSE_BASE_URL)"
LANGFUSE_PUBLIC_KEY_RAW="$(read_from_env_file LANGFUSE_PUBLIC_KEY)"
LANGFUSE_SECRET_KEY_RAW="$(read_from_env_file LANGFUSE_SECRET_KEY)"

if [[ -z "${LANGFUSE_BASE_URL_RAW:-}" || -z "${LANGFUSE_PUBLIC_KEY_RAW:-}" || -z "${LANGFUSE_SECRET_KEY_RAW:-}" ]]; then
  echo "[opencode-lf] Missing one of LANGFUSE_BASE_URL/LANGFUSE_PUBLIC_KEY/LANGFUSE_SECRET_KEY in $ENV_FILE" >&2
  exit 1
fi

export LANGFUSE_BASE_URL="$LANGFUSE_BASE_URL_RAW"
export LANGFUSE_PUBLIC_KEY="$LANGFUSE_PUBLIC_KEY_RAW"
export LANGFUSE_SECRET_KEY="$LANGFUSE_SECRET_KEY_RAW"

# Normalize endpoint. Langfuse OTLP endpoint: /api/public/otel
base="${LANGFUSE_BASE_URL%/}"
export OTEL_EXPORTER_OTLP_ENDPOINT="${base}/api/public/otel"
export OTEL_EXPORTER_OTLP_TRACES_ENDPOINT="${base}/api/public/otel/v1/traces"
export OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
export OTEL_EXPORTER_OTLP_TRACES_PROTOCOL="http/protobuf"

# Basic auth header required by Langfuse OTLP endpoint.
AUTH_STRING="$(python3 - "$LANGFUSE_PUBLIC_KEY" "$LANGFUSE_SECRET_KEY" <<'PY'
import base64
import sys

payload = f"{sys.argv[1]}:{sys.argv[2]}".encode("utf-8")
print(base64.b64encode(payload).decode("ascii"), end="")
PY
)"
export OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic ${AUTH_STRING}"

# Optional but useful metadata for traces.
export OTEL_SERVICE_NAME="opencode"
export OTEL_RESOURCE_ATTRIBUTES="deployment.environment=local,service.version=$(opencode --version 2>/dev/null || echo unknown)"

exec opencode "$@"
