#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
ROOT_DIR="$(cd -- "${SCRIPT_DIR}/.." >/dev/null 2>&1 && pwd)"
source "${SCRIPT_DIR}/opencode-common.sh"

usage() {
  cat <<'EOF'
Usage: opencode-runtime-checks

Runs baseline runtime checks required for guarded OpenCode reviews:
  1) linter
  2) API availability (/api/stats and /api/items)
  3) server liveness stability check

Environment:
  OPENCODE_SKIP_LINT=1           Skip lint check
  OPENCODE_BASE_URL=<url>        Override base URL (default: http://localhost:3000)
  OPENCODE_AUTO_START_SERVER=1   Auto-start local dev server when down (default: 1)
EOF
  print_exit_code_legend
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

require_command curl opencode-runtime-checks
require_command npm opencode-runtime-checks

BASE_URL="${OPENCODE_BASE_URL:-http://localhost:3000}"
AUTO_START="${OPENCODE_AUTO_START_SERVER:-1}"
DEV_SERVER_BIN="${SCRIPT_DIR}/dev-server"

cd "$ROOT_DIR"

if ! curl -fsS "${BASE_URL}/" >/dev/null 2>&1; then
  if [[ "$AUTO_START" == "1" ]]; then
    require_executable_file "$DEV_SERVER_BIN" opencode-runtime-checks
    echo "[runtime-checks] server: ${BASE_URL} is down, starting via scripts/dev-server"
    "$DEV_SERVER_BIN" start
  else
    echo "[runtime-checks] server: ${BASE_URL} is down and auto-start disabled" >&2
    exit_with_code 4
  fi
fi

if [[ "${OPENCODE_SKIP_LINT:-0}" != "1" ]]; then
  echo "[runtime-checks] lint: npm run lint"
  npm run lint >/tmp/opencode-lint.log 2>&1 || {
    echo "[runtime-checks] lint failed. tail:" >&2
    tail -n 40 /tmp/opencode-lint.log >&2 || true
    exit_with_code 4
  }
  echo "[runtime-checks] lint: OK"
else
  echo "[runtime-checks] lint skipped (OPENCODE_SKIP_LINT=1)"
fi

echo "[runtime-checks] server: stability probe"
curl -fsS "${BASE_URL}/" >/tmp/opencode-home-1.html || {
  echo "[runtime-checks] home endpoint unavailable (probe 1)" >&2
  exit_with_code 4
}
sleep 2
curl -fsS "${BASE_URL}/" >/tmp/opencode-home-2.html || {
  echo "[runtime-checks] home endpoint unavailable (probe 2)" >&2
  exit_with_code 4
}

echo "[runtime-checks] api: GET ${BASE_URL}/api/stats"
curl -fsS "${BASE_URL}/api/stats" >/tmp/opencode-stats.json || {
  echo "[runtime-checks] /api/stats unavailable" >&2
  exit_with_code 4
}

echo "[runtime-checks] api: GET ${BASE_URL}/api/items?sort=price&order=desc&minPrice=0&limit=5&offset=0"
curl -fsS "${BASE_URL}/api/items?sort=price&order=desc&minPrice=0&limit=5&offset=0" >/tmp/opencode-items.json || {
  echo "[runtime-checks] /api/items unavailable" >&2
  exit_with_code 4
}

echo "[runtime-checks] api: OK"
echo "[runtime-checks] done"
