#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
ROOT_DIR="$(cd -- "${SCRIPT_DIR}/.." >/dev/null 2>&1 && pwd)"
source "${SCRIPT_DIR}/opencode-common.sh"

usage() {
  cat <<'USAGE'
Usage: opencode-memory-checks

Runs baseline memory checks for guarded OpenCode pipeline:
  1) CodexFi health/status
  2) CodexFi semantic search sanity check
  3) CocoIndex incremental refresh (when changes detected)

Environment:
  OPENCODE_MEMORY_QUERY=<text>         Query for codexfi search
  OPENCODE_REFRESH_COCOINDEX=1         Enable cocoindex refresh (default: 1)
  OPENCODE_COCOINDEX_FORCE=1           Force refresh regardless of change detection
USAGE
  print_exit_code_legend
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

cd "$ROOT_DIR"

if [[ -x "${SCRIPT_DIR}/load-env.sh" && -f "${ROOT_DIR}/.env" ]]; then
  # shellcheck disable=SC2046
  eval "$("${SCRIPT_DIR}/load-env.sh")"
fi

if command -v codexfi >/dev/null 2>&1; then
  CODEXFI_CMD=(codexfi)
else
  require_command bunx opencode-memory-checks
  CODEXFI_CMD=(bunx codexfi)
fi

QUERY="${OPENCODE_MEMORY_QUERY:-d2lut architecture and pipeline decisions}"
REFRESH_COCOINDEX="${OPENCODE_REFRESH_COCOINDEX:-1}"
FORCE_COCOINDEX="${OPENCODE_COCOINDEX_FORCE:-0}"
STAMP_FILE="${ROOT_DIR}/.cocoindex_code/.last_refresh"

should_refresh_cocoindex() {
  if [[ "$FORCE_COCOINDEX" == "1" ]]; then
    return 0
  fi

  if [[ ! -f "${ROOT_DIR}/.cocoindex_code/target_sqlite.db" ]]; then
    return 0
  fi

  if [[ ! -f "$STAMP_FILE" ]]; then
    return 0
  fi

  local changed
  changed="$(find src scripts prisma d2lut -type f -newer "$STAMP_FILE" 2>/dev/null | head -n1 || true)"
  [[ -n "$changed" ]]
}

echo "[memory-checks] codexfi status"
"${CODEXFI_CMD[@]}" status >/tmp/opencode-memory-status.log 2>&1 || {
  echo "[memory-checks] codexfi status failed. tail:" >&2
  tail -n 60 /tmp/opencode-memory-status.log >&2 || true
  exit_with_code 4
}

echo "[memory-checks] codexfi search: ${QUERY}"
"${CODEXFI_CMD[@]}" search "$QUERY" >/tmp/opencode-memory-search.log 2>&1 || {
  echo "[memory-checks] codexfi search failed. tail:" >&2
  tail -n 60 /tmp/opencode-memory-search.log >&2 || true
  exit_with_code 4
}

if [[ "$REFRESH_COCOINDEX" == "1" ]]; then
  if should_refresh_cocoindex; then
    require_command uvx opencode-memory-checks
    echo "[memory-checks] cocoindex refresh: start"
    COCOINDEX_CODE_ROOT_PATH="$ROOT_DIR" \
    uvx --prerelease=explicit --with "cocoindex>=1.0.0a22" cocoindex-code@latest index \
      >/tmp/opencode-cocoindex-refresh.log 2>&1 || {
        echo "[memory-checks] cocoindex refresh failed. tail:" >&2
        tail -n 80 /tmp/opencode-cocoindex-refresh.log >&2 || true
        exit_with_code 4
      }
    mkdir -p "${ROOT_DIR}/.cocoindex_code"
    touch "$STAMP_FILE"
    echo "[memory-checks] cocoindex refresh: OK"
  else
    echo "[memory-checks] cocoindex refresh: skipped (no code changes)"
  fi
else
  echo "[memory-checks] cocoindex refresh: disabled"
fi

echo "[memory-checks] done"
