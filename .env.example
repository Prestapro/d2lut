# D2LUT Environment Variables

# SQLite database path (relative to project root)
DATABASE_URL="file:./data/cache/d2lut.db"

# Secret for /api/cron/refresh-prices endpoint
# Local alias supported: CRON
CRON_SECRET="change-me"

# Optional local/default endpoint for the live d2jsp scraper
API_URL="http://localhost:3000/api/cron/refresh-prices"

# Optional: GitHub token for API access
# GITHUB_TOKEN=ghp_xxxxx
