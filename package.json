{
  "name": "d2lut",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "build": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production node .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:seed": "bunx tsx prisma/seed.ts",
    "db:setup": "prisma generate && prisma migrate deploy && bunx tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "db:sync-catalog": "bunx tsx scripts/sync_full_catalog.ts",
    "db:import-market-snapshot": "bunx tsx scripts/import_market_snapshot.ts",
    "db:import-price-tables": "bunx tsx scripts/import_price_tables.ts",
    "setup:cocoindex": "bash scripts/setup_cocoindex_mcp.sh",
    "setup:hybrid-context": "bash scripts/bootstrap_hybrid_context.sh"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.525.0",
    "next": "^14.2.14",
    "next-themes": "^0.4.6",
    "prisma": "^6.11.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.3",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "bun-types": "^1.3.4",
    "eslint": "8.57.1",
    "eslint-config-next": "^14.2.14",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  }
}
